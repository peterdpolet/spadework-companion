{
  "name": "spadework-companion",
  "displayName": "Spadework Companion",
  "description": "Interactive diagram navigation for Spadework tutorials",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spadework.openDiagram",
        "title": "Open Diagram",
        "category": "Spadework"
      },
      {
        "command": "spadework-companion.traceEpc",
        "title": "Trace EPC from cursor",
        "category": "Spadework"
      }
    ],
    "keybindings": [
      {
        "command": "spadework-companion.traceEpc",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "spadework-companion.traceEpc",
          "when": "editorTextFocus && resourceExtname =~ /\\.(vue|ts|js|py)$/",
          "group": "spadework@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}