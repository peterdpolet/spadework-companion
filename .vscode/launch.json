{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}"
            ],
            "env": {
                "VSCODE_FOLDER": "/home/websites/emillar_v2"
            },
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ]
        }
    ]
}